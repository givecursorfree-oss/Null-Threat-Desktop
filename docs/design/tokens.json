{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "Null Threat App Design Tokens",
    "version": "1.0.0",
    "description": "Desktop application UI design tokens for Null Threat — dark theme, silver/gold brand accents"
  },
  "spacing": {
    "unit": { "$value": "4px", "$type": "dimension", "$description": "Base grid unit" },
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "5": { "$value": "20px", "$type": "dimension" },
    "6": { "$value": "24px", "$type": "dimension" },
    "7": { "$value": "32px", "$type": "dimension" },
    "8": { "$value": "48px", "$type": "dimension" }
  },
  "radius": {
    "sm": { "$value": "4px", "$type": "dimension", "$description": "Chips, small badges" },
    "md": { "$value": "8px", "$type": "dimension", "$description": "Buttons, inputs, cards (default --radius)" },
    "lg": { "$value": "12px", "$type": "dimension", "$description": "Modals, large panels" },
    "xl": { "$value": "16px", "$type": "dimension", "$description": "Hero cards, onboarding panels" }
  },
  "shadow": {
    "elevation-1": {
      "$value": "0 1px 2px 0 rgba(0, 0, 0, 0.4)",
      "$type": "shadow",
      "$description": "Subtle lift — chips, dropdowns"
    },
    "elevation-2": {
      "$value": "0 4px 12px 0 rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255, 255, 255, 0.05)",
      "$type": "shadow",
      "$description": "Cards, popovers, scan result panels"
    },
    "elevation-3": {
      "$value": "0 8px 32px 0 rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(255, 255, 255, 0.08)",
      "$type": "shadow",
      "$description": "Modals, quarantine drawer, onboarding overlay"
    }
  },
  "typography": {
    "caption": {
      "$value": { "fontSize": "11px", "lineHeight": "1.45", "fontWeight": 500 },
      "$type": "typography",
      "$description": "Engine labels, timestamps, table metadata"
    },
    "body-sm": {
      "$value": { "fontSize": "13px", "lineHeight": "1.55", "fontWeight": 400 },
      "$type": "typography",
      "$description": "Secondary descriptions, list items"
    },
    "body": {
      "$value": { "fontSize": "14px", "lineHeight": "1.55", "fontWeight": 400 },
      "$type": "typography",
      "$description": "Primary UI body copy"
    },
    "body-lg": {
      "$value": { "fontSize": "16px", "lineHeight": "1.5", "fontWeight": 400 },
      "$type": "typography",
      "$description": "Onboarding text, settings descriptions"
    },
    "heading-sm": {
      "$value": { "fontSize": "18px", "lineHeight": "1.3", "fontWeight": 600 },
      "$type": "typography",
      "$description": "Card titles, panel headers"
    },
    "heading": {
      "$value": { "fontSize": "24px", "lineHeight": "1.25", "fontWeight": 600 },
      "$type": "typography",
      "$description": "Page titles"
    },
    "display": {
      "$value": { "fontSize": "32px", "lineHeight": "1.15", "fontWeight": 600 },
      "$type": "typography",
      "$description": "Dashboard hero stats, verdict headlines"
    }
  },
  "color": {
    "background": {
      "default": { "$value": "#050505", "$type": "color" },
      "subtle": { "$value": "#0a0a0a", "$type": "color" }
    },
    "surface": {
      "default": { "$value": "#18181b", "$type": "color" },
      "raised": { "$value": "#27272a", "$type": "color" },
      "overlay": { "$value": "rgba(0, 0, 0, 0.75)", "$type": "color" }
    },
    "border": {
      "default": { "$value": "#27272a", "$type": "color" },
      "subtle": { "$value": "rgba(255, 255, 255, 0.05)", "$type": "color" },
      "strong": { "$value": "rgba(255, 255, 255, 0.12)", "$type": "color" }
    },
    "text": {
      "primary": { "$value": "#ffffff", "$type": "color" },
      "secondary": { "$value": "#a1a1aa", "$type": "color" },
      "muted": { "$value": "#71717a", "$type": "color" },
      "disabled": { "$value": "#52525b", "$type": "color" },
      "inverse": { "$value": "#050505", "$type": "color" }
    },
    "interactive": {
      "default": { "$value": "#ffffff", "$type": "color", "$description": "Primary button background" },
      "hover": { "$value": "#e4e4e7", "$type": "color" },
      "active": { "$value": "#d4d4d8", "$type": "color" },
      "disabled": { "$value": "#3f3f46", "$type": "color" }
    },
    "interactive-foreground": {
      "default": { "$value": "#050505", "$type": "color" },
      "hover": { "$value": "#050505", "$type": "color" },
      "active": { "$value": "#050505", "$type": "color" },
      "disabled": { "$value": "#71717a", "$type": "color" }
    },
    "secondary-interactive": {
      "default": { "$value": "#27272a", "$type": "color", "$description": "Ghost/secondary button background" },
      "hover": { "$value": "#3f3f46", "$type": "color" },
      "active": { "$value": "#52525b", "$type": "color" },
      "disabled": { "$value": "#18181b", "$type": "color" }
    },
    "secondary-interactive-foreground": {
      "default": { "$value": "#ffffff", "$type": "color" },
      "hover": { "$value": "#ffffff", "$type": "color" },
      "active": { "$value": "#e4e4e7", "$type": "color" },
      "disabled": { "$value": "#52525b", "$type": "color" }
    },
    "accent": {
      "gold": { "$value": "#d4a017", "$type": "color", "$description": "Brand accent, active scan indicator" },
      "gold-muted": { "$value": "rgba(212, 160, 23, 0.15)", "$type": "color" },
      "silver": { "$value": "#a1a1aa", "$type": "color", "$description": "Neutral brand accent" }
    },
    "semantic": {
      "clean": { "$value": "#34d399", "$type": "color", "$description": "Risk 0–20" },
      "suspicious": { "$value": "#fbbf24", "$type": "color", "$description": "Risk 21–50" },
      "high-risk": { "$value": "#f97316", "$type": "color", "$description": "Risk 51–80" },
      "malware": { "$value": "#ef4444", "$type": "color", "$description": "Risk 81–100" },
      "info": { "$value": "#38bdf8", "$type": "color" },
      "success": { "$value": "#34d399", "$type": "color" },
      "warning": { "$value": "#fbbf24", "$type": "color" },
      "destructive": { "$value": "#ef4444", "$type": "color" }
    },
    "engine": {
      "hash": { "$value": "#38bdf8", "$type": "color" },
      "clamav": { "$value": "#34d399", "$type": "color" },
      "yara": { "$value": "#a855f7", "$type": "color" },
      "deep": { "$value": "#d4a017", "$type": "color" }
    }
  },
  "animation": {
    "duration": {
      "fast": { "$value": "150ms", "$type": "duration", "$description": "Hover states, toggles" },
      "normal": { "$value": "250ms", "$type": "duration", "$description": "Panel transitions, progress bars" },
      "slow": { "$value": "400ms", "$type": "duration", "$description": "Page transitions, modal enter/exit" }
    },
    "easing": {
      "default": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier", "$description": "Standard ease-in-out" },
      "spring": { "$value": "cubic-bezier(0.175, 0.885, 0.32, 1.275)", "$type": "cubicBezier", "$description": "Entrance overshoot — modals, toasts" }
    }
  }
}
